# ===== 智谱 AI 免费 key =====
# 1) 打开 https://bigmodel.cn ，手机号注册（无需企业认证）
# 2) 进入「用量中心 / API Keys」，新建一个 key，复制粘贴到下面等号后
# 3) 拿到 key 后，把最下面的 DEMO_MODE 改成 false，重启 dev server
ZHIPU_API_KEY=your_key_here

# 可选：视觉分析模型（默认 glm-4v-flash 完全免费；若建议被截断可换 glm-4.6v-flash）
# ZHIPU_VISION_MODEL=glm-4v-flash

# 可选：图像生成模型（默认 cogview-3-flash 完全免费）
# ZHIPU_IMAGE_MODEL=cogview-3-flash

# Demo 模式：true=用示例文字建议（无需 key）；false=用智谱真实 AI 分析
# 注意：只要填了 ZHIPU_API_KEY，即使 DEMO_MODE=true 也会生成真实的推荐姿势线稿
DEMO_MODE=false
